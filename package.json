{
  "name": "@tesser-payments/sdk-ts",
  "version": "0.0.3",
  "description": "Signer-only TypeScript SDK for Tesser API: locally stamp signCreateWallet and signStep activities. No HTTP, no OAuth — bring your own client.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tesser-payments/sdk-ts.git"
  },
  "homepage": "https://github.com/tesser-payments/sdk-ts#readme",
  "bugs": {
    "url": "https://github.com/tesser-payments/sdk-ts/issues"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --target=node --format=esm --outdir=./dist --external @tesser-payments/types",
    "build:types": "tsc -p tsconfig.build.json",
    "prepack": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tesser-payments/types": "*"
  },
  "dependencies": {
    "@turnkey/api-key-stamper": "^0.6.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@tesser-payments/types": "*",
    "@types/node": "^20",
    "typescript": "^5.4",
    "vitest": "^2"
  },
  "trustedDependencies": []
}
