# Required by all examples
API_BASE_URL=https://api.tesser.xyz
AUTH_TOKEN_URL=https://auth.tesser.xyz/oauth/token
API_CLIENT_ID=
API_CLIENT_SECRET=

# Signing key (33-byte compressed P-256 hex, prefix 02 or 03)
SIGNING_PUBLIC_KEY=
SIGNING_PRIVATE_KEY=
SIGNING_ENCLAVE_ID=

# create-wallet.ts only
CREATE_WALLET_TYPE=stablecoin_ethereum

# sign-step-*.ts only
FROM_ACCOUNT_ID=
FROM_AMOUNT=
FROM_CURRENCY=
FROM_NETWORK=BASE_SEPOLIA
TO_ACCOUNT_ID=
TO_CURRENCY=
TO_NETWORK=BASE_SEPOLIA

# sign-step-webhooks.ts only
WEBHOOK_PORT=8787
