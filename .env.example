# Tesser API
API_BASE_URL=https://api.tesser.xyz
API_CLIENT_ID=
API_CLIENT_SECRET=

# Optional override for the OAuth token endpoint.
# Default: https://auth.tesser.xyz/oauth/token (per https://docs.tesser.xyz/overviews/authentication)
# AUTH_TOKEN_URL=

# Wallet creation type — one of: stablecoin_ethereum | stablecoin_solana | stablecoin_stellar
CREATE_WALLET_TYPE=stablecoin_ethereum

# Turnkey signing config (from Tesser dashboard)
SIGNING_PUBLIC_KEY=
SIGNING_PRIVATE_KEY=
SIGNING_ENCLAVE_ID=

# Phase B only — RPC URLs for signStep (optional; drpc fallbacks are used if absent)
# RPC_URL_ETHEREUM=
# RPC_URL_POLYGON=
# RPC_URL_BASE=
