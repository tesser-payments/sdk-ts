# Required by all examples
API_BASE_URL=https://api.tesser.xyz
AUTH_TOKEN_URL=https://auth.tesser.xyz/oauth/token
API_CLIENT_ID=
API_CLIENT_SECRET=

# Signing key (33-byte compressed P-256 hex, prefix 02 or 03)
SIGNING_PUBLIC_KEY=
SIGNING_PRIVATE_KEY=
SIGNING_ENCLAVE_ID=

# sign-step-*.ts only
# Required: FROM_ACCOUNT_ID, TO_ACCOUNT_ID.
# Optional fields fall back to the defaults shown.
FROM_ACCOUNT_ID=
FROM_AMOUNT=             # default: 0.000001
FROM_CURRENCY=           # default: USDC
FROM_NETWORK=            # default: BASE_SEPOLIA
TO_ACCOUNT_ID=
TO_CURRENCY=             # default: USDC
TO_NETWORK=              # default: BASE_SEPOLIA

# sign-step-webhooks.ts only
WEBHOOK_PORT=            # default: 8787
